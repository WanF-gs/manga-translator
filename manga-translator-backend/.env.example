# ============================================
# 漫画多语言智能翻译系统 - 后端环境变量配置
# ============================================

# ---- 应用配置 ----
APP_NAME=MangaTranslator
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=DEBUG

# ---- 数据库 ----
DATABASE_URL=postgresql+asyncpg://manga_user:manga_pass@postgres:5432/manga_translator
DATABASE_SYNC_URL=postgresql://manga_user:manga_pass@postgres:5432/manga_translator

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- MinIO / S3 ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=manga-translator
MINIO_SECURE=false

# ---- 网关配置 ----
GATEWAY_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_USER=100
RATE_LIMIT_PER_IP=300
MAX_UPLOAD_SIZE_MB=500

# ---- 微服务地址 ----
USER_SERVICE_URL=http://user-service:8001
PROJECT_SERVICE_URL=http://project-service:8002
TRANSLATION_SERVICE_URL=http://translation-service:8003
IMAGE_SERVICE_URL=http://image-service:8004
EXPORT_SERVICE_URL=http://export-service:8005
READER_SERVICE_URL=http://reader-service:8006

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- 上传配置 ----
UPLOAD_DIR=/app/uploads
MAX_IMAGE_SIZE_MB=50
MAX_ARCHIVE_SIZE_MB=500
ALLOWED_IMAGE_TYPES=png,jpg,jpeg,webp,bmp
ALLOWED_ARCHIVE_TYPES=zip,rar,cbz,cbr,7z

# ---- AI 服务 HTTP 地址 ----
AI_SERVICE_BASE_URL=http://ai-services

# ---- 翻译 API Keys ----
# DeepL (推荐，日→中/英/韩质量好，免费额度50万字符/月)
DEEPL_API_KEY=your-deepl-api-key
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
# Google Cloud Translation
GOOGLE_TRANSLATE_API_KEY=your-google-api-key
# 腾讯云机器翻译
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_TMT_REGION=ap-guangzhou
# OpenAI (用于 multimodal 视觉翻译)
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ---- OCR 回退引擎 ----
TESSERACT_CMD=tesseract
TESSERACT_LANG=jpn+chi_sim+eng+kor

# ---- 字体目录 ----
FONT_DIR=/app/fonts
